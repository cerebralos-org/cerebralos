#!/usr/bin/env bash
# Resolve symlinks to find the real directory (needed for npm link)
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
DIR="$(cd "$(dirname "$SOURCE")/.." && pwd)"
exec node --import "$DIR/src/preload.js" "$DIR/src/cli.js" "$@"
