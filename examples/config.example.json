{
  "version": "3.0.0",
  "user": {
    "name": "Your Name",
    "timezone": "Asia/Tokyo"
  },
  "language": "en",
  "knowledge_repo": "",
  "skill_path": "~/.cerebralos/skills/nightly-dream.md",
  "sleep_job": {
    "enabled": true,
    "schedule": "0 3 * * *",
    "max_insights_per_night": 1
  },
  "active_forgetting": {
    "enabled": true,
    "decay_threshold_days": 30,
    "protected_tags": ["pinned", "project"]
  },
  "intelligence": {
    "enabled": true,
    "command": "claude",
    "timeout_minutes": 10
  },
  "expiry_scan_paths": ["~/Documents"],
  "hygiene_scan_path": "~",
  "integrations": {
    "micro_mcp": {
      "enabled": true,
      "port": 3210,
      "max_tools": 2
    },
    "shell_hook": {
      "enabled": true,
      "trigger": "terminal_open"
    }
  },
  "write": {
    "default_target": "peripheral",
    "auto_tag": true
  }
}
